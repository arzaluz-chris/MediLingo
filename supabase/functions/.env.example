# Edge Function secrets. Copy to supabase/functions/.env for local `supabase
# functions serve`, and set the same keys in the hosted project with
# `supabase secrets set --env-file supabase/functions/.env`.
# NEVER commit the filled-in .env.

# ── AI providers (ai-conversation, generate-exercise-feedback) ───────────────
# Gemini is primary; OpenAI and Anthropic are fallbacks (chatWithFallback).
# At least GEMINI_API_KEY is required for AI features to work.
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# ── RevenueCat webhook (revenuecat-webhook) ──────────────────────────────────
# Shared secret. Set the SAME value as the "Authorization: Bearer <secret>"
# header in the RevenueCat dashboard webhook config.
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# ── Supabase (auto-injected in the hosted platform; needed locally) ──────────
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically when
# deployed. For local `functions serve` they come from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
