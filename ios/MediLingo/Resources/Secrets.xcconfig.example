// Copy to Secrets.xcconfig (gitignored) and fill in. These flow into Info.plist
// via project.yml (INFOPLIST_KEY_SupabaseURL / SupabaseAnonKey) and are read by
// AppConfig at runtime. To wire the file, add `configFiles:` in project.yml or
// set it as the target's base configuration in Xcode.

// Note: xcconfig strips `//` — escape as https:/​/ or store host without scheme
// and rebuild the URL in AppConfig if you hit that. Local default works as-is.
SUPABASE_URL = http://127.0.0.1:54321
SUPABASE_ANON_KEY = your-anon-key

REVENUE_CAT_API_KEY = your-revenuecat-key
POSTHOG_API_KEY = your-posthog-key
