{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medilingo.app/schemas/matching.schema.json",
  "title": "Matching exercise metadata",
  "description": "metadata for exercise_type = 'matching'. Paired items live in exercise_options, grouped by match_pair_id.",
  "type": "object",
