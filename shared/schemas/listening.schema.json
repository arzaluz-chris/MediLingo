{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medilingo.app/schemas/listening.schema.json",
  "title": "Listening exercise metadata",
  "description": "metadata for exercise_type = 'listening'. Audio is in exercises.prompt_audio_url; answer options in exercise_options.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "allow_replay": { "type": "boolean", "default": true },
    "max_replays": { "type": "integer", "minimum": 0, "default": 3 },
    "playback_speeds": {
      "type": "array",
      "items": { "type": "number", "enum": [0.5, 0.75, 1.0, 1.25, 1.5] },
      "default": [0.75, 1.0, 1.25]
    },
    "transcript": { "type": "string" }
  }
}
